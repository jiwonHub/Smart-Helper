<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginBottom="70dp"
    android:background="#F4F6FB">

    <!-- ✅ 상단 헤더 (카테고리 색상으로 동적 변경) -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="?attr/colorPrimary">

            <!-- 배경 그라디언트 뷰 -->
            <View
                android:id="@+id/headerBackground"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#4A90D9"
                app:layout_collapseMode="parallax"/>

            <!-- 헤더 장식 원 -->
            <View
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="end|top"
                android:layout_marginTop="-60dp"
                android:layout_marginEnd="-60dp"
                android:background="@drawable/shape_circle_white_alpha"
                app:layout_collapseMode="parallax"/>

            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="start|bottom"
                android:layout_marginStart="-30dp"
                android:layout_marginBottom="-30dp"
                android:background="@drawable/shape_circle_white_alpha"
                app:layout_collapseMode="parallax"/>

            <!-- 헤더 아이콘 + 타이틀 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="24dp"
                android:orientation="vertical"
                android:gravity="center"
                app:layout_collapseMode="parallax">

                <ImageView
                    android:id="@+id/ivHeaderIcon"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/pills"
                    app:tint="#FFFFFF"/>

                <TextView
                    android:id="@+id/tvHeaderTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="투약 기록"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/tvHeaderSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Medication Record"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/arrow"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="4dp"/>

            </androidx.appcompat.widget.Toolbar>


        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ✅ 스크롤 컨텐츠 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:layout_marginBottom="70dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="100dp">

            <!-- ✅ 날짜 & 시간 카드 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- 섹션 라벨 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <View
                            android:id="@+id/accentBarDateTime"
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="#4A90D9"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="날짜 및 시간"
                            android:textColor="#1A1A2E"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="반복 스케줄"
                            android:textSize="16dp"
                            android:textStyle="bold" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchRepeat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:thumb="@drawable/switch_thumb_bg"
                            app:track="@drawable/switch_track"
                            app:switchMinWidth="52dp"
                            app:switchPadding="4dp"
                            app:showText="false"/>

                    </LinearLayout>

                    <!-- 날짜 + 시간 가로 배치 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <!-- 날짜/요일 선택 영역 (ViewFlipper로 전환) -->
                        <ViewFlipper
                            android:id="@+id/viewFlipperDate"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp">

                            <!-- Page 0: 기존 날짜 선택 -->
                            <LinearLayout
                                android:id="@+id/layoutDate"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_input_field"
                                android:orientation="vertical"
                                android:padding="14dp"
                                android:clickable="true"
                                android:focusable="true">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="📅 날짜"
                                    android:textColor="#9E9E9E"
                                    android:textSize="11sp"/>

                                <TextView
                                    android:id="@+id/tvSelectedDate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="날짜 선택"
                                    android:textColor="#1A1A2E"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>

                            <!-- Page 1: 요일 선택 -->
                            <LinearLayout
                                android:id="@+id/layoutDaySelector"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_input_field"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🔁 반복 요일"
                                    android:textColor="#9E9E9E"
                                    android:textSize="11sp"
                                    android:layout_marginBottom="10dp"/>

                                <!-- 요일 버튼 7개 -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:weightSum="7">

                                    <TextView
                                        android:id="@+id/dayMon"
                                        android:layout_width="0dp"
                                        android:layout_height="32dp"
                                        android:layout_weight="1"
                                        android:layout_marginEnd="2dp"
                                        android:gravity="center"
                                        android:text="월"
                                        android:textSize="12sp"
                                        android:textColor="#1A1A2E"
                                        android:textStyle="bold"
                                        android:background="@drawable/bg_day_unselected"
                                        android:clickable="true"
                                        android:focusable="true"/>

                                    <TextView
                                        android:id="@+id/dayTue"
                                        android:layout_width="0dp"
                                        android:layout_height="32dp"
                                        android:layout_weight="1"
                                        android:layout_marginEnd="2dp"
                                        android:gravity="center"
                                        android:text="화"
                                        android:textSize="12sp"
                                        android:textColor="#1A1A2E"
                                        android:textStyle="bold"
                                        android:background="@drawable/bg_day_unselected"
                                        android:clickable="true"
                                        android:focusable="true"/>

                                    <TextView
                                        android:id="@+id/dayWed"
                                        android:layout_width="0dp"
                                        android:layout_height="32dp"
                                        android:layout_weight="1"
                                        android:layout_marginEnd="2dp"
                                        android:gravity="center"
                                        android:text="수"
                                        android:textSize="12sp"
                                        android:textColor="#1A1A2E"
                                        android:textStyle="bold"
                                        android:background="@drawable/bg_day_unselected"
                                        android:clickable="true"
                                        android:focusable="true"/>

                                    <TextView
                                        android:id="@+id/dayThu"
                                        android:layout_width="0dp"
                                        android:layout_height="32dp"
                                        android:layout_weight="1"
                                        android:layout_marginEnd="2dp"
                                        android:gravity="center"
                                        android:text="목"
                                        android:textSize="12sp"
                                        android:textColor="#1A1A2E"
                                        android:textStyle="bold"
                                        android:background="@drawable/bg_day_unselected"
                                        android:clickable="true"
                                        android:focusable="true"/>

                                    <TextView
                                        android:id="@+id/dayFri"
                                        android:layout_width="0dp"
                                        android:layout_height="32dp"
                                        android:layout_weight="1"
                                        android:layout_marginEnd="2dp"
                                        android:gravity="center"
                                        android:text="금"
                                        android:textSize="12sp"
                                        android:textColor="#1A1A2E"
                                        android:textStyle="bold"
                                        android:background="@drawable/bg_day_unselected"
                                        android:clickable="true"
                                        android:focusable="true"/>

                                    <!-- 토: 파랑 -->
                                    <TextView
                                        android:id="@+id/daySat"
                                        android:layout_width="0dp"
                                        android:layout_height="32dp"
                                        android:layout_weight="1"
                                        android:layout_marginEnd="2dp"
                                        android:gravity="center"
                                        android:text="토"
                                        android:textSize="12sp"
                                        android:textColor="#2979FF"
                                        android:textStyle="bold"
                                        android:background="@drawable/bg_day_unselected"
                                        android:clickable="true"
                                        android:focusable="true"/>

                                    <!-- 일: 빨강 -->
                                    <TextView
                                        android:id="@+id/daySun"
                                        android:layout_width="0dp"
                                        android:layout_height="32dp"
                                        android:layout_weight="1"
                                        android:gravity="center"
                                        android:text="일"
                                        android:textSize="12sp"
                                        android:textColor="#F44336"
                                        android:textStyle="bold"
                                        android:background="@drawable/bg_day_unselected"
                                        android:clickable="true"
                                        android:focusable="true"/>

                                </LinearLayout>
                            </LinearLayout>

                        </ViewFlipper>

                        <!-- 시간 선택 (기존 유지) -->
                        <LinearLayout
                            android:id="@+id/layoutTime"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_input_field"
                            android:orientation="vertical"
                            android:padding="14dp"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⏰ 시간"
                                android:textColor="#9E9E9E"
                                android:textSize="11sp"/>

                            <TextView
                                android:id="@+id/tvSelectedTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="시간 선택"
                                android:textColor="#1A1A2E"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ✅ 세부 내용 카드 (카테고리별 동적 변경 가능) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- 섹션 라벨 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <View
                            android:id="@+id/accentBarDetail"
                            android:layout_width="4dp"
                            android:layout_height="25dp"
                            android:background="#4A90D9"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:id="@+id/tvDetailSectionTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="세부 내용"
                            android:textColor="#1A1A2E"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- 수치 입력 (체온/SpO2 등에서 활용) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="수치 입력"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxStrokeColor="#E0E0E0">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etValue"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:textSize="16sp"/>

                        </com.google.android.material.textfield.TextInputLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="수치 기록"
                                android:textStyle="bold"/>

                            <ImageView
                                android:id="@+id/btnSearchHistory"
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:padding="6dp"
                                android:layout_gravity="center"
                                android:src="@drawable/history"
                                android:contentDescription="설정"
                                android:background="?attr/selectableItemBackgroundBorderless" />


                        </LinearLayout>


                    </LinearLayout>


                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ✅ 메모 카드 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- 섹션 라벨 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <View
                            android:id="@+id/accentBarMemo"
                            android:layout_width="4dp"
                            android:layout_height="25dp"
                            android:background="#4A90D9"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="메모"
                            android:textColor="#1A1A2E"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilMemo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="특이사항을 입력해주세요...(선택사항)"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#E0E0E0">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMemo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minLines="4"
                            android:gravity="top"
                            android:inputType="textMultiLine"
                            android:textSize="15sp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ✅ 하단 저장 버튼 (Floating) -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardCornerRadius="0dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:weightSum="3">

            <!-- 취소 버튼 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="취소"
                android:textSize="16sp"
                android:textColor="#757575"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="14dp"
                app:strokeColor="#E0E0E0"/>

            <!-- 저장 버튼 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="2"
                android:layout_marginStart="8dp"
                android:text="💾  저장하기"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4A90D9"
                app:cornerRadius="14dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
