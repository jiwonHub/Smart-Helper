<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    android:padding="20dp"
    android:layout_marginBottom="70dp">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineRight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.68"/>

    <!-- ✅ 좌측: 캘린더 카드 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardCalendar"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginEnd="12dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guidelineRight"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/calendarArea"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp">

            <!-- ✅ 헤더 배경 (그라디언트) -->
            <View
                android:id="@+id/calendarHeaderBg"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/gradient_calendar_header"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/divider"/>

            <!-- 년월 텍스트 -->
            <TextView
                android:id="@+id/tvMonthYear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2025년 11월"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="5dp"
                android:layout_marginTop="10dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@id/headerRow"/>

            <!-- 이전 달 버튼 -->
            <ImageView
                android:id="@+id/btnPrevMonth"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/left_arrow"
                android:background="@drawable/bg_circle_white_alpha"
                android:padding="6dp"
                android:layout_marginEnd="10dp"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintEnd_toStartOf="@id/tvMonthYear"
                app:layout_constraintTop_toTopOf="@id/tvMonthYear"
                app:layout_constraintBottom_toBottomOf="@id/tvMonthYear"
                app:tint="#FFFFFF" />

            <!-- 다음 달 버튼 -->
            <ImageView
                android:id="@+id/btnNextMonth"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/right_arrow"
                android:background="@drawable/bg_circle_white_alpha"
                android:padding="6dp"
                android:layout_marginStart="10dp"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintStart_toEndOf="@id/tvMonthYear"
                app:layout_constraintTop_toTopOf="@id/tvMonthYear"
                app:layout_constraintBottom_toBottomOf="@id/tvMonthYear"
                app:tint="#FFFFFF" />



            <!-- 요일 헤더 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/headerRow"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="4dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvMonthYear">

                <TextView android:id="@+id/tvSun"
                    android:layout_width="0dp" android:layout_height="match_parent"
                    android:text="일" android:textSize="13sp"
                    android:textColor="#FF6B6B" android:gravity="center"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/tvMon"
                    app:layout_constraintTop_toTopOf="parent"/>

                <TextView android:id="@+id/tvMon"
                    android:layout_width="0dp" android:layout_height="match_parent"
                    android:text="월" android:textSize="13sp"
                    android:textColor="#FFFFFFCC" android:gravity="center"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/tvSun"
                    app:layout_constraintEnd_toStartOf="@id/tvTue"
                    app:layout_constraintTop_toTopOf="parent"/>

                <TextView android:id="@+id/tvTue"
                    android:layout_width="0dp" android:layout_height="match_parent"
                    android:text="화" android:textSize="13sp"
                    android:textColor="#FFFFFFCC" android:gravity="center"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/tvMon"
                    app:layout_constraintEnd_toStartOf="@id/tvWed"
                    app:layout_constraintTop_toTopOf="parent"/>

                <TextView android:id="@+id/tvWed"
                    android:layout_width="0dp" android:layout_height="match_parent"
                    android:text="수" android:textSize="13sp"
                    android:textColor="#FFFFFFCC" android:gravity="center"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/tvTue"
                    app:layout_constraintEnd_toStartOf="@id/tvThu"
                    app:layout_constraintTop_toTopOf="parent"/>

                <TextView android:id="@+id/tvThu"
                    android:layout_width="0dp" android:layout_height="match_parent"
                    android:text="목" android:textSize="13sp"
                    android:textColor="#FFFFFFCC" android:gravity="center"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/tvWed"
                    app:layout_constraintEnd_toStartOf="@id/tvFri"
                    app:layout_constraintTop_toTopOf="parent"/>

                <TextView android:id="@+id/tvFri"
                    android:layout_width="0dp" android:layout_height="match_parent"
                    android:text="금" android:textSize="13sp"
                    android:textColor="#FFFFFFCC" android:gravity="center"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/tvThu"
                    app:layout_constraintEnd_toStartOf="@id/tvSat"
                    app:layout_constraintTop_toTopOf="parent"/>

                <TextView android:id="@+id/tvSat"
                    android:layout_width="0dp" android:layout_height="match_parent"
                    android:text="토" android:textSize="13sp"
                    android:textColor="#82B4FF" android:gravity="center"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/tvFri"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 구분선 -->
            <View
                android:id="@+id/divider"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="#1A000000"
                android:layout_marginTop="4dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/headerRow"/>

            <!-- 날짜 그리드 RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCalendar"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="6dp"
                android:overScrollMode="never"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- ✅ 우측 일정 패널 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSchedulePanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="10dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintStart_toEndOf="@id/guidelineRight"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- 패널 상단 그라디언트 배경 -->
            <View
                android:id="@+id/panelHeaderBg"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:background="@drawable/gradient_calendar_header"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <!-- 선택된 날짜 타이틀 -->
            <TextView
                android:id="@+id/tvSelectedDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="날짜를 선택하세요"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/panelHeaderBg"
                app:layout_constraintBottom_toBottomOf="@id/panelHeaderBg"/>

            <!-- 일정 없을 때 표시 -->
            <TextView
                android:id="@+id/tvEmptySchedule"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="이 날의 일정이 없습니다."
                android:textSize="13sp"
                android:textColor="#BBBBBB"
                android:gravity="center"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/panelHeaderBg"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <!-- 일정 목록 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSchedule"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:paddingTop="8dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clipToPadding="false"
                android:overScrollMode="never"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/panelHeaderBg"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
