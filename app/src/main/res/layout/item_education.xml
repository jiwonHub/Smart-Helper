<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 상단 정보 영역 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:paddingBottom="12dp">

            <!-- 썸네일 아이콘 영역 -->
            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginEnd="14dp">

                <TextView
                    android:id="@+id/tvThumbnailEmoji"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="🫁"
                    android:textSize="26sp"
                    android:gravity="center"
                    android:background="@drawable/edu_thumb_bg"/>
            </FrameLayout>

            <!-- 텍스트 정보 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- 카테고리 + 완료 뱃지 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="5dp">

                    <TextView
                        android:id="@+id/tvCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="의료기기"
                        android:textSize="11sp"
                        android:textColor="#3B82F6"
                        android:textStyle="bold"
                        android:background="@drawable/cat_label_blue_bg"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/tvCompletedBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓ 완료"
                        android:textSize="11sp"
                        android:textColor="#16A34A"
                        android:textStyle="bold"
                        android:background="@drawable/cat_label_green_bg"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:visibility="gone"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="흡인기 사용 방법"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1E2D3D"
                    android:layout_marginBottom="3dp"/>

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="가정에서 흡인기를 안전하게 사용하는 방법을 단계별로 안내합니다"
                    android:textSize="12sp"
                    android:textColor="#7A8FA6"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:layout_marginBottom="6dp"/>

                <!-- 시간 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏱"
                        android:textSize="11sp"
                        android:layout_marginEnd="4dp"/>

                    <TextView
                        android:id="@+id/tvDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8분 23초"
                        android:textSize="12sp"
                        android:textColor="#7A8FA6"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!--  하단 버튼 -->
        <TextView
            android:id="@+id/btnWatch"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="▶  영상 시청"
            android:gravity="center"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_watch_blue_bg"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
