<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootItem"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:paddingStart="4dp"
    android:paddingEnd="4dp">

    <!-- 수치 텍스트 -->
    <TextView
        android:id="@+id/tvValue"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="#1A1A2E"
        android:fontFamily="sans-serif"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tvDefaultBadge"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- 현재 기본값 배지 (기본값인 항목만 표시) -->
    <TextView
        android:id="@+id/tvDefaultBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="기본값"
        android:textSize="11sp"
        android:textColor="#4A90D9"
        android:background="@drawable/bg_badge_blue"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:visibility="gone"
        app:layout_constraintEnd_toStartOf="@id/ivSelector"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginEnd="12dp"/>

    <!-- 선택 원형 아이콘 -->
    <ImageView
        android:id="@+id/ivSelector"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:background="@drawable/bg_circle_empty"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginEnd="8dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
